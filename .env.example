# OLX Partner API – register at https://developer.olx.pl
OLX_CLIENT_ID=your_olx_client_id
OLX_CLIENT_SECRET=your_olx_client_secret
OLX_REDIRECT_URI=http://localhost:3001/api/auth/olx/callback

# Anthropic Claude API
ANTHROPIC_API_KEY=sk-ant-...

# Server
PORT=3001
# IMPORTANT: change to ngrok/localtunnel URL when publishing listings
# OLX requires publicly accessible image URLs
PUBLIC_BASE_URL=http://localhost:3001

# Database
DB_PATH=./data/olx_automation.db

# Price reduction defaults
DEFAULT_PRICE_REDUCTION_PERCENT=10
DEFAULT_REDUCTION_INTERVAL_DAYS=14
MIN_PRICE_PLN=10

# Frontend (Vite – must be prefixed VITE_)
VITE_API_BASE_URL=http://localhost:3001
